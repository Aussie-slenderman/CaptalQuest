rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UIDs — these accounts can read/write/delete anything
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'theosmales1@gmail.com' ||
        request.auth.uid == 'fHa29UBqm7eBZETVqFR1rHlh2K53'
      );
    }

    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();

      match /notifications/{notifId} {
        allow read, delete: if request.auth.uid == userId || isAdmin();
        allow create: if request.auth != null;
      }
    }

    // Portfolios: any authenticated user can read (needed for leaderboard);
    // only owner can write
    match /portfolios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Transactions: owner only (admin can also read/delete)
    match /transactions/{txId} {
      allow read, delete: if request.auth.uid == resource.data.userId || isAdmin();
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // Leaderboard: all authenticated users can read; write only your own entry
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Clubs: public clubs readable by all authenticated users
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.ownerId
                    || resource.data.memberIds.hasAny([request.auth.uid]);
    }

    // Chat rooms: participants only
    match /chatRooms/{roomId} {
      allow read: if request.auth != null
                  && resource.data.participantIds.hasAny([request.auth.uid]);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && resource.data.participantIds.hasAny([request.auth.uid]);

      // Messages in a room
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/chatRooms/$(roomId))
                       .data.participantIds.hasAny([request.auth.uid]);
        allow create: if request.auth.uid == request.resource.data.senderId;
      }
    }

    // Trade proposals: sender or receiver
    match /tradeProposals/{proposalId} {
      allow read: if request.auth.uid == resource.data.fromUserId
                  || request.auth.uid == resource.data.toUserId;
      allow create: if request.auth.uid == request.resource.data.fromUserId;
      allow update: if request.auth.uid == resource.data.toUserId;
    }
  }
}
